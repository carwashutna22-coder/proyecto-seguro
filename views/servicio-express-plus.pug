include layout/header.pug
include layout/menu.pug

.container.mt-5

  h1.text-center Exterior Express Plus
  p.text-center.text-muted Lavado rápido con acabado mejorado

  .text-center.mt-4
    img.img-servicio(src="/img/EEP.jpg")

  .mt-4
    p.text-center.mt-3
      | Exterior Express Plus mejora el lavado rápido tradicional,
      | agregando protección extra y mejor acabado en menos tiempo.
    p.text-center.mt-3
      | Ideal para quienes desean un brillo superior sin largas esperas.

  p.text-success.text-center.mt-3
    strong ¡Mayor brillo en menos tiempo!

  // ===== SERVICIOS =====

  // BÁSICO
  .card.card-servicio.mt-5
    h2.titulo-servicio.text-center Express Plus Básico

    .contenido-servicio
      ul.lista-servicio
        li Lavado completo
        li Espuma activa
        li Secado profesional
        li Limpieza de llantas

      .precio-box
        span.precio $90

  // PREMIUM
  .card.card-servicio.mt-4
    h2.titulo-servicio.text-center Express Plus Premium

    .contenido-servicio
      ul.lista-servicio
        li Lavado profundo
        li Cera protectora
        li Brillo en llantas
        li Protección de pintura

      .precio-box
        span.precio $120

  // DELUXE (DESTACADO)
  .card.card-servicio.destacado.mt-4
    .badge-popular Más solicitado

    h2.titulo-servicio.text-center Express Plus Deluxe

    .contenido-servicio
      ul.lista-servicio
        li Lavado completo
        li Cera selladora
        li Secado premium
        li Acabado brillante

      .precio-box
        span.precio $150

  // NOTA
  p.text-muted.mt-3
    | *Duración aproximada: 10 a 15 minutos.*

  // BOTÓN
  .text-center.mt-5
    a.btn.btn-primary(href="/servicios") Volver a servicios


// ===== FOOTER =====
footer.mt-5(style="background:#111; color:white; padding:30px;")
  .container
    .row

      .col-md-3
        h5 Sobre nosotros
        p Desde su apertura en 1998, UTNACAR WASH ha brindado servicio a clientes que buscan un lavado de autos de alta calidad a un precio accesible, con atención profesional y resultados confiables.

      .col-md-3
        h5 Nuestros servicios
        ul
          li Lavado exterior exprés
          li Limpieza interior
          li Lavado completo
          li Detallado exprés
          li Encerado protector
          li Mantenimiento preventivo

      .col-md-3
        h5 Enlaces útiles
        ul
          li Inicio
          li Servicios y precios
          li Promociones
          li Nosotros
          li Ubicación
          li Contáctanos

      .col-md-3
        h5 Información de contacto
        p Llámanos ahora:
        p 458 109 6668
        p Guadalupe, Zacatecas
        p Lunes a sábado: 8:00 a.m. – 6:00 p.m.
        p Domingo: 9:00 a.m. – 3:00 p.m.

  .text-center.mt-3
    p ©2026 UTNACAR WASH. Todos los derechos reservados.
