include layout/header.pug
include layout/menu.pug

.container.mt-5

  h1.text-center Servicio Completo Plus
  p.text-center.text-muted Servicio total con acabado premium superior

  .text-center.mt-4
    img.img-servicio(src="/img/SCP.jpg")

  .mt-4
    p.text-center.mt-3
      | Este servicio combina todos nuestros procesos en un solo paquete,
      | brindando una limpieza total con resultados de alta calidad.
    p.text-center.mt-3
      | Ideal para quienes desean dejar su vehículo como nuevo.

  p.text-success.text-center.mt-3
    strong ¡El mejor servicio disponible!

  // ===== SERVICIOS =====

  // PLUS
  .card.card-servicio.mt-5
    .badge-popular Más solicitado

    h2.titulo-servicio.text-center Servicio Completo Plus

    .contenido-servicio
      ul.lista-servicio
        li Lavado exterior
        li Limpieza interior
        li Aspirado profundo
        li Limpieza de vidrios
        li Brillo de llantas

      .precio-box
        span.precio $250

  // FULL PREMIUM
  .card.card-servicio.mt-4
    h2.titulo-servicio.text-center Servicio Full Premium

    .contenido-servicio
      ul.lista-servicio
        li Pulido profesional
        li Encerado premium
        li Protección de pintura
        li Limpieza completa
        li Acabado brillante

      .precio-box
        span.precio $320

  // DELUXE (DESTACADO)
  .card.card-servicio.destacado.mt-4
    .badge-vip PREMIUM

    h2.titulo-servicio.text-center Servicio Total Deluxe

    .contenido-servicio
      ul.lista-servicio
        li Todo lo anterior
        li Protección UV
        li Tratamiento interior
        li Detallado completo
        li Acabado de exhibición

      .precio-box
        span.precio $380


  // ===== SERVICIOS EXTRA =====
  .mt-5
    h3.text-center Servicios adicionales

    .row
      .col-md-6
        ul
          li Ambientador - $20
          li Brillo de llantas - $30
          li Cera extra - $50

      .col-md-6
        ul
          li Limpieza de motor - $150
          li Pulido especial - $200
          li Protección cerámica - $300

  // BOTÓN
  .text-center.mt-5
    a.btn.btn-primary(href="/servicios") Volver a servicios


// ===== FOOTER =====
footer.mt-5(style="background:#111; color:white; padding:30px;")
